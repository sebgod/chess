@page "/"
@using System.Collections.Immutable
@using Chess.Lib
@using Chess.Lib.UI
@using DIR.Lib
@using WebGl.Renderer
@using Action = Chess.Lib.Action
@inject IJSRuntime JS
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>Chess — Blazor/WASM</PageTitle>

<div class="app">
    <header>
        <h1>Chess <span class="tag">@(_backend == RenderBackend.WebGl ? "webgl" : "cpu")</span></h1>
        <p class="blurb">
            The full chess engine (<code>Chess.Lib</code>) compiled to WebAssembly — board, rules,
            and the negamax AI all running <em>entirely in this tab</em>. Rendering:
            @(_backend == RenderBackend.WebGl
                ? "GPU via WebGl.Renderer — MSDF text from a pre-baked atlas, our own rasterizer end to end."
                : "software (DIR.Lib RgbaImageRenderer) blitted to a 2D canvas.")
            <a href="@(_backend == RenderBackend.WebGl ? "?renderer=cpu" : "?renderer=webgl")">
                switch to @(_backend == RenderBackend.WebGl ? "CPU" : "WebGL")</a>
        </p>
    </header>

    @* Visible only while loading; once the canvas is live the status renders in the display's
       own status bar (in-canvas, like the desktop GUI). Post-ready the paragraph goes sr-only —
       screen readers keep the live announcements, and the board never shifts when text rewraps. *@
    <p class="status @(_ready ? "sr-only" : null)" aria-live="polite">@_status</p>

    @* Shared hi-dpi canvas host (WebGl.Renderer): sizes the backing buffer to the laid-out CSS
       box × devicePixelRatio, reports metrics, and maps pointer coords into backing space.
       Display size comes from app.css's canvas#board rule (aspect-locked 760/840). *@
    <WebGlCanvas @ref="_canvas" Id="board" TabIndex="0"
                 OnReady="OnCanvasReadyAsync"
                 OnResized="OnCanvasResizedAsync"
                 OnPointerDown="OnPointerDownAsync"
                 OnKeyDown="OnKeyDownAsync" />

    @if (_screen == Screen.Setup)
    {
        <div class="controls">
            <button class="new" @onclick="FinishSetupAsync" disabled="@_busy">▶ Start game</button>
            <button @onclick="BackToMenuAsync" disabled="@_busy">↩ Menu</button>
        </div>
    }
    else if (_screen == Screen.Playing)
    {
        <div class="controls">
            <button class="new" @onclick="BackToMenuAsync" disabled="@_busy">↻ New game</button>
            @if (_vsComputer)
            {
                <label>AI depth
                    <select @onchange="OnDepthChanged" disabled="@_busy">
                        <option value="2" selected="@(_aiDepth == 2)">2</option>
                        <option value="3" selected="@(_aiDepth == 3)">3</option>
                        <option value="4" selected="@(_aiDepth == 4)">4</option>
                    </select>
                </label>
            }
        </div>
    }
</div>

@code {
    // Logical design size — the desktop GUI's window proportions, since the canvas now hosts the
    // same PixelGameDisplay chrome (board + history panel + status bar). The REAL pixel size
    // comes from WebGlCanvas metrics (_backingW/_backingH = laid-out CSS box x devicePixelRatio);
    // these constants remain only as the aspect reference mirrored by app.css's aspect-ratio.
    const int BoardW = 1050;
    const int BoardH = 830;

    enum RenderBackend { WebGl, Cpu }

    // The canvas shows one of three things: the startup wizard, board setup (custom game), or a
    // live game.
    enum Screen { Menu, Setup, Playing }

    Game _game = null!;
    RenderBackend _backend = RenderBackend.WebGl;
    WebGlRenderer? _webGl;
    RgbaImageRenderer? _cpu;

    // Board + history panel + status bar — the same PixelGameDisplay the desktop GUI draws,
    // bound to whichever renderer is live. The non-generic face gives the page one reference;
    // the display owns GameUI (created in ResetGame, replaced in OnResize).
    IPixelGameDisplay _display = null!;
    GameUI Ui => _display.UI;

    WebGlCanvas _canvas = null!;
    // Backing-buffer pixel dimensions, updated from WebGlCanvas metrics. Everything renders and
    // hit-tests in this space (GameUI, menu widgets, clip rects, blit).
    uint _backingW = BoardW;
    uint _backingH = BoardH;
    // Resolved by the canvas's first metrics report — init awaits this instead of guessing when
    // the canvas is laid out (replaces the old firstRender/_pendingPaint workaround).
    readonly TaskCompletionSource<CanvasMetrics> _canvasReady = new();

    // The startup menu reuses DIR.Lib's backend-neutral PixelMenuWidget — the same widget the
    // desktop Vulkan GUI draws. Only the one matching the active backend is constructed.
    PixelMenuWidget<WebGlContext>? _webMenu;
    PixelMenuWidget<RgbaImage>? _cpuMenu;

    Screen _screen = Screen.Menu;
    // The shared wizard state machine (Chess.Lib.UI) — same flow/content as desktop + console;
    // this page only presents Current through the menu widget and forwards confirms.
    StartupWizard _wizard = new();
    bool _vsComputer = true;
    // Side to move for a custom game, from the wizard; consumed when setup finishes.
    Side _setupSideToMove = Side.White;

    Side _humanSide = Side.White;
    int _aiDepth = 3;
    bool _busy;
    bool _ready;
    string _status = "Loading…";

    // Must match PixelGameDisplay's internal background — the display's GameUI paints margins
    // with it, and the host clears the rest of the surface; a mismatch would band.
    static readonly RGBAColor32 Background = PixelGameDisplay<WebGlContext>.Background;

    static string SdfCacheDir => System.IO.Path.Combine(AppContext.BaseDirectory, "sdfcache");

    protected override async Task OnInitializedAsync()
    {
        // Default WebGL; ?renderer=cpu forces the software path (also the A/B reference
        // for verifying MSDF output, and the fallback for devices without WebGL2).
        if (new Uri(Nav.Uri).Query.Contains("renderer=cpu", StringComparison.OrdinalIgnoreCase))
            _backend = RenderBackend.Cpu;

        await LoadFontsAsync();

        // The canvas's first metrics report tells us the real backing size (CSS box x dpr) —
        // and doubles as the "canvas is in the DOM and laid out" gate that renderer init needs.
        var metrics = await _canvasReady.Task;
        _backingW = metrics.BackingWidth;
        _backingH = metrics.BackingHeight;

        if (_backend == RenderBackend.WebGl)
        {
            try
            {
                await LoadSdfCacheAsync(); // best-effort; a miss only costs runtime rasterization
                // readOnly: single-threaded WASM has no writer thread; the pre-baked cache is
                // load-only. Raster size/spread must match the bake (the shared atlas constants).
                _webGl = await WebGlRenderer.CreateAsync("board", _backingW, _backingH,
                    diskCache: new SdfGlyphDiskCache(SdfCacheDir,
                        SdfFontAtlas.SdfRasterSize, SdfFontAtlas.SdfSpread, readOnly: true));
                // Pull the pre-baked glyphs into the atlas NOW, while "Loading…" shows —
                // otherwise the first frame rasterizes every visible glyph inline (seconds on
                // an interpreted WASM host).
                _status = "Preparing glyphs…";
                StateHasChanged();
                _webGl.PrimeFonts(FontPaths.Merida, FontPaths.DejaVuSans);
                Console.WriteLine($"[chess-web] webgl ready — atlas: {_webGl.Atlas.FrameStats}");
            }
            catch (Exception ex)
            {
                // WebGL2 unavailable (or the module failed to load): fall back to software.
                Console.Error.WriteLine($"[chess-web] WebGL init failed, using CPU renderer: {ex}");
                _backend = RenderBackend.Cpu;
            }
        }
        if (_backend == RenderBackend.Cpu)
            _cpu = new RgbaImageRenderer(_backingW, _backingH);

        // Construct the menu widget + game display for whichever renderer we ended up with.
        if (_backend == RenderBackend.WebGl)
        {
            _webMenu = new PixelMenuWidget<WebGlContext>(_webGl!, FontPaths.DejaVuSans);
            _display = new PixelGameDisplay<WebGlContext>(_webGl!);
        }
        else
        {
            _cpuMenu = new PixelMenuWidget<RgbaImage>(_cpu!, FontPaths.DejaVuSans);
            _display = new PixelGameDisplay<RgbaImage>(_cpu!);
        }

        _ready = true;
        ShowWizardStep();
        await RenderMenuAsync(); // canvas + renderer are guaranteed live here — paint directly
    }

    Task OnCanvasReadyAsync(CanvasMetrics metrics)
    {
        _canvasReady.TrySetResult(metrics);
        return Task.CompletedTask;
    }

    // Window resize / reflow / devicePixelRatio change: resize the live renderer + UI in place
    // and repaint whatever screen is showing. Menu widgets track the renderer's size on their
    // own; only GameUI bakes pixel sizes in at construction (Resize returns a NEW instance).
    async Task OnCanvasResizedAsync(CanvasMetrics metrics)
    {
        if (!_ready) return; // pre-init reports are consumed via _canvasReady

        _backingW = metrics.BackingWidth;
        _backingH = metrics.BackingHeight;

        if (_backend == RenderBackend.WebGl)
            _webGl!.Resize(_backingW, _backingH);
        else
            _cpu!.Resize(_backingW, _backingH);

        // Recomputes the board/history/status split and rebuilds GameUI at the new size
        // (state-preserving); a no-op until the first ResetGame.
        _display.OnResize((int)_backingW, (int)_backingH);

        if (_screen == Screen.Menu)
            await RenderMenuAsync();
        else
            await RenderBoardAsync();
    }

    // .NET's WASM runtime has a working in-memory filesystem, and GameUI resolves
    // fonts as AppContext.BaseDirectory/Fonts/*.ttf. Fetch the bytes from wwwroot
    // and drop them at that exact path so the managed rasterizer's LoadFromFile
    // finds them — no library change needed.
    async Task LoadFontsAsync()
    {
        var dir = FontPaths.FontsDirectory;
        System.IO.Directory.CreateDirectory(dir);
        foreach (var name in new[] { "DejaVuSans.ttf", "Merida.ttf" })
        {
            var dest = System.IO.Path.Combine(dir, name);
            if (!System.IO.File.Exists(dest))
            {
                var bytes = await Http.GetByteArrayAsync($"Fonts/{name}");
                await System.IO.File.WriteAllBytesAsync(dest, bytes);
            }
        }
    }

    // Same trick for the pre-baked MSDF atlas: fetch each .sdfg (content-hash names come from
    // manifest.txt, one per line) into the in-memory FS dir the read-only SdfGlyphDiskCache
    // points at. Missing cache (e.g. a dev run without a bake) is fine — glyphs rasterize
    // inline on first use instead; only startup speed differs.
    async Task LoadSdfCacheAsync()
    {
        // Fully best-effort: any miss (no bake in a dev run, a blocked fetch, …) must degrade to
        // runtime rasterization, never take down the WebGL path itself.
        try
        {
            var manifest = await Http.GetStringAsync("sdfcache/manifest.txt");
            System.IO.Directory.CreateDirectory(SdfCacheDir);
            var loaded = 0;
            foreach (var line in manifest.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
            {
                // Files ship as {hash}.sdfg.bin (static hosts need a known MIME extension);
                // SdfGlyphDiskCache expects {hash}.sdfg on disk, so strip the suffix here.
                var destName = line.EndsWith(".bin", StringComparison.Ordinal) ? line[..^4] : line;
                var dest = System.IO.Path.Combine(SdfCacheDir, destName);
                if (!System.IO.File.Exists(dest))
                {
                    var bytes = await Http.GetByteArrayAsync($"sdfcache/{line}");
                    await System.IO.File.WriteAllBytesAsync(dest, bytes);
                }
                loaded++;
            }
            Console.WriteLine($"[chess-web] sdf cache: {loaded} file(s) staged");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[chess-web] no pre-baked sdf cache ({ex.Message}) — rasterizing at runtime");
        }
    }

    // ---- startup wizard -------------------------------------------------------------------------

    // Loads the wizard's current step into whichever menu widget is live (Reset also clears the
    // widget's confirmed flag).
    void ShowWizardStep()
    {
        var (title, prompt, items) = _wizard.Current;
        _webMenu?.Reset(title, prompt, [..items]);
        _cpuMenu?.Reset(title, prompt, [..items]);
        _status = "Choose how you'd like to play.";
    }

    // A click in menu mode: dispatch to the widget (a hit both selects and confirms the item),
    // then advance the wizard or start the game. Coords arrive pre-mapped to backing space.
    async Task HandleMenuClickAsync(CanvasPointerEventArgs e)
    {
        var confirmed = DispatchMenu(new InputEvent.MouseDown(e.X, e.Y));
        if (confirmed is { } sel)
            await ConfirmWizardAsync(sel);
        // A click that misses every item confirms nothing and changes nothing — no redraw needed.
    }

    // Keyboard: in the menu, arrows move the highlight and Enter/digits confirm; in a game the
    // keys route to GameUI.HandleKeyDown — the desktop bindings (a–h/1–8 square entry, promotion
    // letters, Ctrl+arrows / Esc playback, setup piece keys + s to start).
    async Task OnKeyDownAsync(KeyboardEventArgs e)
    {
        if (!_ready || _busy) return;

        if (_screen == Screen.Menu)
        {
            // Same key map as gameplay: MenuModel consumes arrows/Enter/digits, ignores the rest.
            if (MapGameKey(e.Key) is not { } key) return;

            var confirmed = DispatchMenu(new InputEvent.KeyDown(key));
            if (confirmed is { } sel)
                await ConfirmWizardAsync(sel);
            else
                await RenderMenuAsync(); // selection moved — repaint the highlight
            return;
        }

        if (MapGameKey(e.Key) is not { } gameKey) return;
        var modifiers = e.CtrlKey ? InputModifier.Ctrl : InputModifier.None;

        var (response, _) = Ui.HandleKeyDown(gameKey, modifiers);

        // 's' ends setup inside GameUI — mirror the Start button's freeze-and-play handoff.
        if (_screen == Screen.Setup && !Ui.IsSetupMode)
        {
            await FinishSetupAsync();
            return;
        }

        if (response == UIResponse.None) return;

        _status = StatusText();
        await RenderBoardAsync();
        StateHasChanged();

        if (_screen == Screen.Playing && response.HasFlag(UIResponse.IsUpdate))
            await MaybeAiMoveAsync(); // a keyboard-entered move may hand the turn to the AI
    }

    // Maps browser KeyboardEvent.key values to the DIR.Lib keys GameUI binds (desktop keymap).
    // Tab (browser focus nav) and F-keys (browser chrome) deliberately stay unmapped — their
    // GameUI actions have on-page buttons instead.
    static InputKey? MapGameKey(string key) => key switch
    {
        "ArrowUp" => InputKey.Up,
        "ArrowDown" => InputKey.Down,
        "ArrowLeft" => InputKey.Left,
        "ArrowRight" => InputKey.Right,
        "Escape" => InputKey.Escape,
        "Enter" => InputKey.Enter,
        "Delete" => InputKey.Delete,
        "Backspace" => InputKey.Backspace,
        "PageUp" => InputKey.PageUp,
        "PageDown" => InputKey.PageDown,
        [var c] when char.IsAsciiLetter(c) => InputKey.A + (char.ToLowerInvariant(c) - 'a'),
        [var c] when char.IsAsciiDigit(c) => InputKey.D0 + (c - '0'),
        _ => null,
    };

    // Dispatches an event to the live menu widget; returns the confirmed index, else null.
    // (A hit/Enter/digit both selects and confirms; an arrow only moves the selection.)
    int? DispatchMenu(InputEvent ev) => _backend == RenderBackend.WebGl
        ? ClickMenu(_webMenu!, ev)
        : ClickMenu(_cpuMenu!, ev);

    static int? ClickMenu<TSurface>(PixelMenuWidget<TSurface> menu, InputEvent ev)
    {
        menu.HandleInput(ev);
        return menu.IsConfirmed ? menu.SelectedIndex : null;
    }

    // Feeds a confirmed item into the shared wizard: either advance to the next step, or map the
    // finished Result onto this page's state and start the chosen game.
    async Task ConfirmWizardAsync(int selected)
    {
        _wizard.Confirm(selected);
        if (!_wizard.IsComplete)
        {
            ShowWizardStep();
            await RenderMenuAsync();
            return;
        }

        var (mode, computerSide, sideToMove) = _wizard.Result;
        _vsComputer = computerSide != Side.None;
        _humanSide = computerSide == Side.White ? Side.Black : Side.White;
        _setupSideToMove = sideToMove;

        if (mode is GameMode.CustomGameEmpty or GameMode.CustomGameStandardBoard)
            await EnterSetupAsync(emptyBoard: mode == GameMode.CustomGameEmpty);
        else
            await StartPlayingAsync();
    }

    // Maps a browser KeyboardEvent.key to the menu-relevant DIR.Lib keys (MenuModel handles the
    // rest: Up/Down wrap, Enter confirms, D1/D2 select-and-confirm). Returns null to ignore.

    async Task StartPlayingAsync()
    {
        _screen = Screen.Playing;
        StartNewGame();
        await RenderBoardAsync();
        await MaybeAiMoveAsync(); // if the human chose Black, White (the AI) opens
    }

    async Task BackToMenuAsync()
    {
        _busy = false;
        _display.StatusOverride = null;
        _screen = Screen.Menu;
        _wizard = new StartupWizard();
        ShowWizardStep();
        await RenderMenuAsync();
    }

    // ---- custom game: board setup ---------------------------------------------------------------

    // Opens GameUI's setup mode on an empty or standard board. All placement — selecting a square,
    // picking a piece from the on-board palette, toggling the placement colour — is handled by
    // GameUI via the normal click routing; the display's status bar shows the setup hints.
    async Task EnterSetupAsync(bool emptyBoard)
    {
        _screen = Screen.Setup;
        _game = emptyBoard ? new Game(new Board(), _setupSideToMove, []) : new Game();
        _display.ResetGame(_game);
        Ui.IsSetupMode = true;
        _busy = false;
        _status = "Set up the board: click a square, then pick a piece. The swatch toggles colour; Start begins the game.";
        await RenderBoardAsync();
    }

    // Leaves setup: freeze the arranged board into a fresh game with the chosen side to move, then
    // play it (the engine opens if it holds the side to move).
    async Task FinishSetupAsync()
    {
        if (_screen != Screen.Setup) return;
        var setupBoard = _game.Board;
        _game = new Game(setupBoard, _setupSideToMove, []);
        _display.ResetGame(_game);
        _screen = Screen.Playing;
        _busy = false;
        _status = StatusText();
        await RenderBoardAsync();
        await MaybeAiMoveAsync();
    }

    // ---- gameplay -------------------------------------------------------------------------------

    void StartNewGame()
    {
        _game = new Game();
        _display.ResetGame(_game); // builds GameUI at the display's board area (total − chrome)
        _busy = false;
        _status = StatusText();
    }

    async Task OnPointerDownAsync(CanvasPointerEventArgs e)
    {
        if (!_ready || _busy) return;

        if (_screen == Screen.Menu)
        {
            await HandleMenuClickAsync(e);
            return;
        }

        if (_screen == Screen.Setup)
        {
            // Placement/selection/colour-toggle — GameUI handles it; setup never auto-finishes.
            Ui.HandleMouseDown(e.X, e.Y);
            await RenderBoardAsync();
            return;
        }

        // No IsFinished gate: after mate the history panel stays clickable (playback review),
        // exactly like the desktop; GameUI/Game reject board moves on a finished game.
        var (response, _) = Ui.HandleMouseDown(e.X, e.Y);
        await RenderBoardAsync();

        if (response.HasFlag(UIResponse.IsUpdate))
        {
            _status = StatusText();
            await MaybeAiMoveAsync();
        }
    }

    // Drives the AI while it is the computer's turn. No-op in Player-vs-Player. Single-threaded
    // WASM means the search blocks the UI thread; the short Delay lets the "thinking" state paint first.
    async Task MaybeAiMoveAsync()
    {
        if (!_vsComputer)
        {
            _busy = false;
            _status = StatusText();
            StateHasChanged();
            return;
        }

        while (!_game.IsFinished && _game.CurrentSide != _humanSide)
        {
            _busy = true;
            _status = $"{_game.CurrentSide} (AI) thinking…";
            // The canvas status bar shows the transient state too — paint it before the search
            // blocks the single WASM thread; the short Delay lets the frame reach the screen.
            _display.StatusOverride = _status;
            StateHasChanged();
            await RenderBoardAsync();
            await Task.Delay(20);

            var ai = new AiEngine(_game.CurrentSide, maxDepth: _aiDepth);
            var move = ai.PickMove(_game);
            if (move is not { } mv) break;
            _game.TryMove(mv);

            _display.StatusOverride = null;
            _status = StatusText();
            await RenderBoardAsync();
        }
        _busy = false;
        _display.StatusOverride = null;
        _status = StatusText();
        StateHasChanged();
    }

    // ---- rendering ------------------------------------------------------------------------------

    async Task RenderMenuAsync()
    {
        if (_backend == RenderBackend.WebGl)
        {
            _webGl!.Clear(Background);
            _webMenu!.Render();
            _webGl.Present(); // synchronous [JSImport] flush — one interop call per frame
        }
        else
        {
            _cpu!.Surface.Clear(Background);
            _cpuMenu!.Render();
            await JS.InvokeVoidAsync("chessCanvas.blit", "board", _backingW, _backingH, _cpu.Surface.Pixels);
        }
        // Focus the canvas (so arrow/Enter reach it without a click first) and suppress the
        // page-scroll default for those keys while the menu is up.
        await JS.InvokeVoidAsync("chessCanvas.enableMenuKeys", "board", true);
    }

    // One frame of the game screen: the display draws board + history panel + status bar
    // (and rebuilds its click regions — history hit-testing needs the fresh frame).
    async Task RenderBoardAsync()
    {
        if (_backend == RenderBackend.WebGl)
        {
            _webGl!.Clear(Background);
            _display.Render();
            _webGl.Present(); // synchronous [JSImport] flush — one interop call per frame
        }
        else
        {
            _cpu!.Surface.Clear(Background);
            _display.Render();
            // Blazor marshals a byte[] argument to JS as a Uint8Array; the buffer is
            // already tightly-packed RGBA, exactly what ImageData wants.
            await JS.InvokeVoidAsync("chessCanvas.blit", "board", _backingW, _backingH, _cpu.Surface.Pixels);
        }
    }

    void OnDepthChanged(ChangeEventArgs e)
    {
        if (int.TryParse((string?)e.Value, out var d)) _aiDepth = d;
    }

    string StatusText()
        => _game.GameStatus.ToMessage(_game.IsFinished ? _game.Winner : _game.CurrentSide);
}
